  },
  "devDependencies": {
    "@types/cors": "^2.8.12",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.2.5",
