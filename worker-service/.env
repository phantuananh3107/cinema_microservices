# # Database Configuration
# DB_DSN=postgres://user:password@localhost:5432/cinema_db
# DB_PASSWORD=your_password

# # Redis Configuration
# REDIS_URL=redis://localhost:6379

# # Gemini API Keys (comma-separated for round-robin load balancing)
# # Single key example:
# # GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# #
# # Multiple keys example (recommended for high volume):
# GEMINI_API_KEY=AIzaSyBu2XgkR9GCDxxj329lVs1clkUQefIyA64


# ==============================
# DATABASE
# ==============================
DB_DSN=postgres://postgres:postgres@postgres:5432/cinema_app?sslmode=disable
DB_READONLY_DSN=postgres://postgres:postgres@postgres:5432/cinema_app?sslmode=disable
DB_PASSWORD=postgres
DB_READONLY_PASSWORD=postgres

# ==============================
# REDIS (FULL)
# ==============================
REDIS_URL=redis://redis:6379/0

REDIS_CACHE_URL=redis://redis:6379/1
REDIS_CACHE_READONLY_URL=redis://redis:6379/1

REDIS_MUTEX_URL=redis://redis:6379/2
REDIS_LIMITER_URL=redis://redis:6379/3

REDIS_PUBSUB_URL=redis://redis:6379/4
REDIS_PUBSUB_READONLY_URL=redis://redis:6379/4

# ==============================
# AI
# ==============================
GEMINI_API_KEY=AIzaSyBu2XgkR9GCDxxj329lVs1clkUQefIyA64