PORT=8086
SERVICE_NAME=payment-service

# ==============================
# DATABASE
# ==============================
DB_CONNECTION=postgres
DB_DSN=postgresql://postgres:postgres@postgres:5432/cinema_app?sslmode=disable
DB_READONLY_DSN=postgresql://postgres:postgres@postgres:5432/cinema_app?sslmode=disable
DB_PASSWORD=postgres
DB_READONLY_PASSWORD=postgres
DB_MAX_OPEN_CONNECTIONS=100

# ==============================
# REDIS
# ==============================
REDIS_URL=redis://redis:6379/0

REDIS_CACHE_URL=redis://redis:6379/1
REDIS_CACHE_READONLY_URL=redis://redis:6379/1

REDIS_PUBSUB_URL=redis://redis:6379/2
REDIS_PUBSUB_READONLY_URL=redis://redis:6379/2

# ==============================
# ENV
# ==============================
NODE_ENV=production